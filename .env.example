# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/edulumix

# JWT Secret (min 32 characters)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Enable background cron jobs (set false on non-leader instances)
ENABLE_CRON_JOBS=true

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
# Additional allowed origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://staging.edulumix.in,https://preview.example.com

# Groq API (for EduLumix chatbot)
GROQ_API_KEY=your_groq_api_key

# Firebase (for Firebase Auth - Google/Email login)
# FIREBASE_PROJECT_ID=edulumix-2b55d
# Option 1: JSON string of service account (paste entire JSON as one line)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# Option 2: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./config/edulumix-service-account.json

# Super Admin Credentials (for initial seed)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@edulumix.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# External Job APIs (Adzuna India + JSearch)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_JSEARCH_HOST=jsearch.p.rapidapi.com
