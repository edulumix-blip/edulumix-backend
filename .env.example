# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/edulumix

# JWT Secret (min 32 characters)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Server Port
PORT=5000

# Node Environment (use development locally — production applies stricter API rate limits)
NODE_ENV=development

# API rate limit: max requests per IP per 15 minutes for /api/* (default 100 prod, 5000 non-prod)
# RATE_LIMIT_MAX=2000
# Or disable entirely (local debugging only): DISABLE_API_RATE_LIMIT=true

# Enable background cron jobs (set false on non-leader instances)
ENABLE_CRON_JOBS=true

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
# Additional allowed origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://staging.edulumix.in,https://preview.example.com

# Groq API (for EduLumix chatbot) — get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
# Optional override (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant
# Optional extra lines appended to the chatbot system prompt (English-only rules still apply)
# EDULUMIX_CHAT_EXTRA_CONTEXT=

# Firebase (for Firebase Auth - Google/Email login)
# FIREBASE_PROJECT_ID=edulumix-2b55d
# Option 1: JSON string of service account (paste entire JSON as one line)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# Option 2: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./config/edulumix-service-account.json

# Super Admin Credentials (for initial seed)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@edulumix.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# External Job APIs (Adzuna India + JSearch)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_JSEARCH_HOST=jsearch.p.rapidapi.com

# Job fetch (Adzuna + JSearch): daily 3:50 AM IST by default
# JOB_FETCH_CRON_SCHEDULE=50 3 * * *
# JOB_FETCH_CRON_TIMEZONE=Asia/Kolkata
# JOB_FETCH_CRON_ENABLED=false

# Resource fetch: every N hours (interval from server start, default 40). Separate from tech blog.
# RESOURCE_FETCH_INTERVAL_HOURS=40
# RESOURCE_FETCH_CRON_ENABLED=false

# Tech blog auto-fetch (Dev.to + Medium): every 12 hours at :00 in timezone
# BLOG_FETCH_CRON_SCHEDULE=0 */12 * * *
# BLOG_FETCH_CRON_TIMEZONE=Asia/Kolkata
# BLOG_FETCH_CRON_ENABLED=false
